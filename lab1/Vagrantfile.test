# _*_ mode: ruby _*_
# vi: set ft=ruby :

VAGRANTFILE_API_VERSION= "2"

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  # GEneral Vagrant VM Configuration
  config.vm.box = "Centos"
  config.ssh.insert_key = false
  config.vm.synced_folder ".", "/vagrant" , disabled: true
  config.vm.provider :virtualbox do |v|
    v.memory = 512
    v.linked_clone = true
  end

  # Application server 3
  config.vm.define "app3" do |app|
    app.vm.hostname = "orc-app3.test"
    app.vm.network :private_network, ip: "192.168.56.74"
  end

  # Application server 4
  config.vm.define "app4" do |app|
    app.vm.hostname = "orc-app4.test"
    app.vm.network :private_network, ip: "192.168.56.75"
  end

  # Database server
  config.vm.define "db" do |db|
    db.vm.hostname = "orc-db2.test"
    db.vm.network :private_network, ip: "192.168.56.76"
  end
end
